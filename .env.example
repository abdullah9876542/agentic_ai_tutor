# Copy this file to .env and fill in your values
# Command: cp .env.example .env

# ── OpenAI ───────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key-here

# ── App ──────────────────────────────────────────────────────────
FASTAPI_HOST=http://localhost:8000
DATABASE_URL=sqlite:///./data/tutor.db
UPLOAD_DIR=uploads

# ── Email (Gmail SMTP) ───────────────────────────────────────────
# To enable email notifications:
# 1. Use a Gmail account
# 2. Enable 2-Step Verification on the account
# 3. Go to Google Account → Security → App Passwords
# 4. Create an App Password (select "Mail" and your device)
# 5. Paste the 16-character App Password below (no spaces)
EMAIL_SENDER=your-gmail@gmail.com
EMAIL_APP_PASSWORD=your-16-char-app-password
EMAIL_SENDER_NAME=Agentic AI Tutor

# ── Email Notifications (Phase 8) ────────────────────────────────
# Use Gmail with an App Password (NOT your regular password)
# How to get a Gmail App Password:
#   1. Go to myaccount.google.com → Security → 2-Step Verification (enable it)
#   2. Go to myaccount.google.com → Security → App passwords
#   3. Create a new App Password for "Mail"
#   4. Paste the 16-character password below (no spaces)
#
# For other providers: change SMTP_HOST and SMTP_PORT accordingly
#   Outlook: smtp-mail.outlook.com / 587
#   Yahoo:   smtp.mail.yahoo.com   / 587

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
EMAIL_SENDER=your_gmail@gmail.com
EMAIL_PASSWORD=your_16_char_app_password
EMAIL_FROM_NAME=AI Tutor System
